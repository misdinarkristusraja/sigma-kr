# ============================================================
# SIGMA App — Environment Variables
# Salin file ini menjadi .env.local untuk development
# Untuk production: set di Vercel Dashboard → Settings → Environment Variables
# ============================================================

# Supabase — wajib
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# URL Aplikasi (untuk generate QR)
VITE_APP_URL=https://sigma.krsoba.id

# Salt untuk generate MyID/CheckSum (jaga kerahasiaan!)
VITE_MYID_SALT=sigma-krsoba-2026-secret-salt

# Secret key untuk Edge Function reset password
# Harus sama dengan SIGMA_SECRET di Supabase Edge Function Secrets
# Gunakan string acak panjang, contoh: sigma-krsoba-reset-2026-xK9mP3rQwZ
VITE_SIGMA_SECRET=sigma-krsoba-reset-2026-GANTI-INI

# gcatholic.org base URL
VITE_GCATHOLIC_BASE_URL=https://gcatholic.org/calendar

# Lingkungan (development | production)
VITE_ENV=development
